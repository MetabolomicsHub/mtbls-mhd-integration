  "protocols": [
    {
      "name": "Sample collection",
      "protocol_type": {
        "source": "EFO",
        "accession": "EFO:0005518",
        "name": "sample collection protocol"
      },
      "description": "Two types of samples were prepared. A mixture of 45 metabolites, representing a variety of chemical classes (sugars, organic acids, amino acids, sugar phosphates), was prepared for GC-MS analysis. 10 µl of the mixture was transferred to a GC-MS vial insert and evaporated to dryness in vacuo. The samples were resuspended in 20 mg/ml methoxyamine in pyridine (20 µl, 16 hr, 25 °C) with continuous shaking, followed by derivatization with BSTFA + 1% TMCS (Pierce; 20 µl, 1 hr, 25 °C) using a Gerstel MPS2 autosampler robot. Second group a Foetal calf serum was spiked with 2-fold increasing amounts of a mix of metabolite standards."
    },
    {
      "name": "Extraction",
      "protocol_type": {
        "source": "MS",
        "accession": "MS:1000831",
        "name": "sample preparation"
      },
      "description": "The Foetal calf serum samples (120 µl) were extracted by the addition of 200 µl of 3:2 chloroform:methanol, followed by vigorous mixing and incubation on ice for 10 min. Samples were centrifuged at 4 °C for 10 mins at 16,000 rpm to enable biphasic sparation. 15 µl of the upper aqueous phase was transferred to GC-MS vial inserts and dried in vacuo. The samples were resuspended in 20 mg/ml methoxyamine in pyridine (20 µl, 16 hr, 25 °C) with continuous shaking, followed by derivatization with BSTFA + 1% TMCS (Pierce; 20 µl, 1 hr, 25 °C) using a Gerstel MPS2 autosampler robot.",
      "protocol_parameters": [
        {
          "key": {
            "source": "",
            "accession": "",
            "name": "derivatization"
          },
          "values": [
            {
              "source": "",
              "accession": "",
              "name": "sylilation"
            }
          ]
        },
        {
          "key": {
            "source": "",
            "accession": "",
            "name": "post extraction"
          },
          "values": [
            {
              "source": "",
              "accession": "",
              "name": "None"
            },
            {
              "source": "",
              "accession": "",
              "name": "20 mg/ml methoxyamine in pyridine"
            }
          ]
        }
      ]
    },
    {
      "name": "Chromatography",
      "protocol_type": {
        "source": "CHMO",
        "accession": "CHMO:0001000",
        "name": "chromatography"
      },
      "description": "Gas chromatography was performed using a 30 m VF5-MS column with 0.25 mm inner diameter and 0.25 mm film thickness (Varian Inc.). Agilent 7890A gas chromatograph interfaced with a 5975C mass selective detector.",
      "protocol_parameters": [
        {
          "key": {
            "source": "OBI",
            "accession": "OBI:0000038",
            "name": "chromatography column"
          },
          "values": [
            {
              "source": "",
              "accession": "",
              "name": "VF-5ms GC (0.25 µm, 0.25 mm x 30 m; Varian)"
            }
          ]
        },
        {
          "key": {
            "source": "OBI",
            "accession": "OBI:0000485",
            "name": "chromatography instrument"
          },
          "values": [
            {
              "source": "MS",
              "accession": "MS:1003741",
              "name": "7890A"
            }
          ]
        },
        {
