            "accession": "MS:1002270",
            "name": "chromatography separation"
          },
          "values": [
            {
              "source": "MS",
              "accession": "MS:1003718",
              "name": "non-polar stationary phase gas-liquid chromatography"
            }
          ]
        }
      ]
    },
    {
      "name": "Mass spectrometry",
      "protocol_type": {
        "source": "CHMO",
        "accession": "CHMO:0000470",
        "name": "mass spectrometry"
      },
      "description": "The injection temperature was 250 °C, the interface set at 280 °C, and the ionsource adjusted to 250 °C. The carrier gas was helium (flow rate 1 ml/min). The temperature program was 1 min isothermal heating at 70 °C, followed by a 1 °C/min oven temperature ramp to 76 °C, then 5 °C/min to 325 °C and held for 10 min. Mass spectra were recorded at 2.66 scans/s (m/z 50–600).",
